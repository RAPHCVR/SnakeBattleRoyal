{
  "name": "snake-duel-arena",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace @snake-duel/shared",
    "predev": "npm run build --workspace @snake-duel/shared",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "health:public": "node scripts/public-health.mjs",
    "qa:smoke": "node scripts/ui-smoke.mjs",
    "prod:check": "npm run typecheck && npm run test && npm run build",
    "prod:check:full": "npm run prod:check && npm run qa:smoke",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build --remove-orphans",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down --remove-orphans",
    "deploy:prod": "node scripts/deploy-prod.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "playwright": "^1.58.2",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  }
}
